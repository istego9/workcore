{
  auto_https off
}

:{$PROXY_PORT:8080} {
  @builder host {$PUBLIC_BUILDER_HOST:builder.localhost}
  handle @builder {
    reverse_proxy {$BUILDER_UPSTREAM_HOST:127.0.0.1}:{$BUILDER_PORT:5183}
  }

  @api host {$PUBLIC_API_HOST:api.localhost}
  handle @api {
    reverse_proxy {$API_UPSTREAM_HOST:127.0.0.1}:{$ORCH_PORT:8000}
  }

  @chatkit host {$PUBLIC_CHATKIT_HOST:chatkit.localhost}
  handle @chatkit {
    reverse_proxy {$CHATKIT_UPSTREAM_HOST:127.0.0.1}:{$CHATKIT_PORT:8001}
  }

  handle {
    respond "unknown host" 404
  }
}
