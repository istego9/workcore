# Local environment template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
# Optional for Agents SDK mode: responses | chat_completions
OPENAI_API=responses

# Optional Azure OpenAI (when set, orchestrator uses Azure client)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
STREAMING_BACKEND=memory
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=workflow-events
KAFKA_GROUP_ID=workflow-sse
WEBHOOK_DEFAULT_INTEGRATION_KEY=default
WEBHOOK_DEFAULT_INBOUND_SECRET=

# ChatKit service (self-hosted)
CHATKIT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workflow
CHATKIT_AUTH_TOKEN=
CHATKIT_OBJECT_ENDPOINT=localhost:9000
CHATKIT_OBJECT_ACCESS_KEY=minioadmin
CHATKIT_OBJECT_SECRET_KEY=minioadmin
CHATKIT_OBJECT_BUCKET=chatkit
CHATKIT_OBJECT_SECURE=false
CHATKIT_OBJECT_PREFIX=chatkit
CHATKIT_UPLOAD_EXPIRES_SECONDS=3600
CHATKIT_OBJECT_CREATE_BUCKET=true
CHATKIT_IDEMPOTENCY_TTL_SECONDS=300
CHATKIT_STT_MODEL=gpt-4o-mini-transcribe
CHATKIT_STT_API_KEY=
CHATKIT_STT_TIMEOUT_SECONDS=30
CHATKIT_STT_MAX_AUDIO_BYTES=10485760
CHATKIT_STT_ALLOWED_MEDIA_TYPES=audio/webm,audio/ogg,audio/mp4
# integration_http egress policy (deny-by-default)
INTEGRATION_HTTP_ALLOWED_HOSTS=api.example.com
INTEGRATION_HTTP_ALLOWED_SCHEMES=https
INTEGRATION_HTTP_ALLOW_PRIVATE_NETWORKS=false
INTEGRATION_HTTP_DENY_CIDRS=169.254.169.254/32
# Internal MCP bridge (runtime MCP execution path)
MCP_BRIDGE_BASE_URL=http://localhost:8002
MCP_BRIDGE_AUTH_TOKEN=
MCP_BRIDGE_REQUEST_TIMEOUT_SECONDS=30
MCP_BRIDGE_MAX_RESPONSE_BYTES=2097152
MCP_BRIDGE_UPSTREAM_CALL_URL=
MCP_BRIDGE_UPSTREAM_AUTH_TOKEN=
MCP_BRIDGE_UPSTREAM_TIMEOUT_SECONDS=30
MCP_BRIDGE_MAX_TIMEOUT_SECONDS=120
MCP_BRIDGE_MAX_ARGUMENTS_BYTES=1048576
MCP_BRIDGE_ALLOWED_SERVERS=
MCP_BRIDGE_ALLOWED_TOOLS=
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://builder.localhost:8080,https://hq21.build,http://hq21.build

# Builder ChatKit UI
VITE_CHATKIT_PAGE=http://builder.localhost:8080/chatkit.html
VITE_CHAT_FORK_PAGE=http://builder.localhost:8080/chat-fork.html
VITE_CHAT_FRONTEND_MODE=chatkit
VITE_CHATKIT_API_URL=http://chatkit.localhost:8080/chatkit
VITE_CHATKIT_DOMAIN_KEY=
VITE_CHATKIT_AUTH_TOKEN=
