<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.workcore.stack</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>__WORKCORE_AUTOSTART_DIR__/workcore_autostart_boot.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__WORKCORE_AUTOSTART_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/workcore/stack.out.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/workcore/stack.err.log</string>
  </dict>
</plist>
