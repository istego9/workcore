# Docker-local WorkCore stack
# Copy to .env.docker and adjust values when needed.

WORKCORE_HTTP_PORT=8080
WORKCORE_HTTPS_PORT=8443
# Optional override for non-standard local ports:
# WORKCORE_HTTP_PORT=18080
# WORKCORE_HTTPS_PORT=18443
PUBLIC_BUILDER_HOST=workcore.build
PUBLIC_API_HOST=api.workcore.build
PUBLIC_API_HOST_ALT=api.workcore.build
PUBLIC_CHATKIT_HOST=chatkit.workcore.build
BUILDER_UPSTREAM_HOST=builder
BUILDER_UPSTREAM_PORT=5173
API_UPSTREAM_HOST=orchestrator
API_UPSTREAM_PORT=8000
CHATKIT_UPSTREAM_HOST=chatkit
CHATKIT_UPSTREAM_PORT=8001

# Optional custom cert paths used by scripts/docker_certs.sh
# WORKCORE_CERTS_DIR=.certs
# WORKCORE_CERT_FILE=.certs/workcore.build.pem
# WORKCORE_CERT_KEY_FILE=.certs/workcore.build-key.pem

POSTGRES_DB=workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
CHATKIT_OBJECT_BUCKET=chatkit
CHATKIT_OBJECT_PREFIX=chatkit
CHATKIT_UPLOAD_EXPIRES_SECONDS=3600
CHATKIT_IDEMPOTENCY_TTL_SECONDS=300
CHATKIT_STT_MODEL=gpt-4o-mini-transcribe
CHATKIT_STT_API_KEY=
CHATKIT_STT_TIMEOUT_SECONDS=30
CHATKIT_STT_MAX_AUDIO_BYTES=10485760
CHATKIT_STT_ALLOWED_MEDIA_TYPES=audio/webm,audio/ogg,audio/mp4

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
# Optional for Agents SDK mode: responses | chat_completions
OPENAI_API=responses

# Optional Azure OpenAI (when set, orchestrator uses Azure client)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AGENT_EXECUTOR_MODE=mock

CHATKIT_AUTH_TOKEN=dev_chatkit_token
VITE_CHATKIT_AUTH_TOKEN=dev_chatkit_token
VITE_CHATKIT_DOMAIN_KEY=

# Required for orchestrator API requests.
WORKCORE_API_AUTH_TOKEN=dev_workcore_api_token

WEBHOOK_DEFAULT_INTEGRATION_KEY=default
WEBHOOK_DEFAULT_INBOUND_SECRET=dev_workcore_inbound_secret

# Must include your builder origin (with explicit ports when non-default).
CORS_ALLOW_ORIGINS=http://workcore.build,https://workcore.build,http://workcore.build:8080,https://workcore.build:8443,http://hq21.build,https://hq21.build

# integration_http egress policy (deny-by-default)
INTEGRATION_HTTP_ALLOWED_HOSTS=api.workcore.build,api.example.com
INTEGRATION_HTTP_ALLOWED_SCHEMES=https
INTEGRATION_HTTP_ALLOW_PRIVATE_NETWORKS=false
INTEGRATION_HTTP_DENY_CIDRS=169.254.169.254/32

# Optional explicit URLs for builder bundle.
# Use protocol-relative URLs so both HTTP and HTTPS local modes work.
VITE_API_BASE_URL=//api.workcore.build
VITE_API_AUTH_TOKEN=dev_workcore_api_token
VITE_CHATKIT_PAGE=//workcore.build/chatkit.html
VITE_CHAT_FORK_PAGE=//workcore.build/chat-fork.html
VITE_CHAT_FRONTEND_MODE=chatkit
VITE_CHATKIT_API_URL=//chatkit.workcore.build/chatkit
VITE_ALLOWED_HOSTS=workcore.build,builder.localhost,localhost,127.0.0.1
