# Docker-local WorkCore stack
# Copy to .env.docker and adjust values when needed.

WORKCORE_HTTP_PORT=80
WORKCORE_HTTPS_PORT=443
PUBLIC_BUILDER_HOST=workcore.build
PUBLIC_API_HOST=api.workcore.build
PUBLIC_CHATKIT_HOST=chatkit.workcore.build

# Optional custom cert paths used by scripts/docker_certs.sh
# WORKCORE_CERTS_DIR=.certs
# WORKCORE_CERT_FILE=.certs/workcore.build.pem
# WORKCORE_CERT_KEY_FILE=.certs/workcore.build-key.pem

POSTGRES_DB=workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
CHATKIT_OBJECT_BUCKET=chatkit
CHATKIT_OBJECT_PREFIX=chatkit
CHATKIT_UPLOAD_EXPIRES_SECONDS=3600
CHATKIT_IDEMPOTENCY_TTL_SECONDS=300

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
AGENT_EXECUTOR_MODE=mock

CHATKIT_AUTH_TOKEN=dev_chatkit_token
VITE_CHATKIT_AUTH_TOKEN=dev_chatkit_token
VITE_CHATKIT_DOMAIN_KEY=

# If enabled, add bearer token support in consumers.
WORKCORE_API_AUTH_TOKEN=

WEBHOOK_DEFAULT_INTEGRATION_KEY=default
WEBHOOK_DEFAULT_INBOUND_SECRET=

# Must include your builder origin (with port if not 80).
CORS_ALLOW_ORIGINS=http://workcore.build,https://workcore.build,http://hq21.build,https://hq21.build

# Optional explicit URLs for builder bundle.
# Use protocol-relative URLs so both HTTP and HTTPS local modes work.
VITE_API_BASE_URL=//api.workcore.build
VITE_CHATKIT_PAGE=//workcore.build/chatkit.html
VITE_CHATKIT_API_URL=//chatkit.workcore.build/chatkit
VITE_ALLOWED_HOSTS=workcore.build,builder.localhost,localhost,127.0.0.1
