{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workcore.build/schemas/workflow-export-v1.schema.json",
  "title": "WorkCore Workflow Export v1",
  "description": "Portable JSON export generated by Builder (More -> Export JSON).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "exported_at", "workflow", "draft"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "workflow_export_v1"
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow_id": {
          "type": ["string", "null"]
        },
        "active_version_id": {
          "type": ["string", "null"]
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] }
      }
    },
    "draft": {
      "$ref": "./workflow-draft.schema.json"
    }
  }
}
