{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workcore.build/schemas/workflow-draft.schema.json",
  "title": "WorkCore Workflow Draft",
  "description": "Editable workflow graph used by Builder and Workflow API draft endpoints.",
  "type": "object",
  "additionalProperties": false,
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "variables_schema": {
      "type": "object"
    }
  },
  "$defs": {
    "nodeType": {
      "type": "string",
      "enum": [
        "start",
        "agent",
        "mcp",
        "integration_http",
        "if_else",
        "while",
        "set_state",
        "interaction",
        "approval",
        "output",
        "end"
      ]
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "target"],
      "properties": {
        "condition": { "type": "string" },
        "target": { "type": "string" }
      }
    },
    "whileConfig": {
      "type": "object",
      "required": ["condition", "max_iterations", "body_target", "exit_target", "loop_back"],
      "properties": {
        "ui": { "$ref": "#/$defs/ui" },
        "condition": { "type": "string" },
        "max_iterations": { "type": "integer", "minimum": 1 },
        "body_target": { "type": "string" },
        "exit_target": { "type": "string" },
        "loop_back": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ifElseConfig": {
      "type": "object",
      "required": ["branches"],
      "properties": {
        "ui": { "$ref": "#/$defs/ui" },
        "branches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/branch" }
        },
        "else_target": { "type": "string" }
      },
      "additionalProperties": true
    },
    "setStateAssignment": {
      "type": "object",
      "required": ["target", "expression"],
      "properties": {
        "target": { "type": "string" },
        "expression": { "type": "string" }
      },
      "additionalProperties": false
    },
    "setStateConfig": {
      "type": "object",
      "properties": {
        "ui": { "$ref": "#/$defs/ui" },
        "target": { "type": "string" },
        "expression": { "type": "string" },
        "assignments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/setStateAssignment" }
        }
      },
      "anyOf": [{ "required": ["target", "expression"] }, { "required": ["assignments"] }],
      "additionalProperties": true
    },
    "integrationHttpConfig": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "ui": { "$ref": "#/$defs/ui" },
        "url": { "type": "string", "minLength": 1 },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "default": "GET"
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "auth": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["none", "bearer", "basic"], "default": "none" },
            "token": { "type": "string" },
            "token_env": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" },
            "username_env": { "type": "string" },
            "password_env": { "type": "string" }
          },
          "additionalProperties": true
        },
        "timeout_s": { "type": "number", "minimum": 0.1 },
        "retry_attempts": { "type": "integer", "minimum": 0, "default": 0 },
        "retry_backoff_s": { "type": "number", "minimum": 0, "default": 0 },
        "request_body_expression": { "type": "string" },
        "response_state_target": { "type": "string" },
        "response_body_state_target": { "type": "string" },
        "fail_on_status": { "type": "boolean", "default": true },
        "allowed_statuses": {
          "type": "array",
          "items": { "type": "integer", "minimum": 100, "maximum": 599 }
        }
      },
      "additionalProperties": true
    },
    "nodeConfig": {
      "type": "object",
      "properties": {
        "ui": { "$ref": "#/$defs/ui" },
        "capability_id": { "type": "string" },
        "capability_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/nodeType" },
        "config": { "$ref": "#/$defs/nodeConfig" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "while" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "config": { "$ref": "#/$defs/whileConfig" } },
            "required": ["config"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "if_else" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "config": { "$ref": "#/$defs/ifElseConfig" } },
            "required": ["config"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "set_state" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "config": { "$ref": "#/$defs/setStateConfig" } },
            "required": ["config"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "integration_http" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "config": { "$ref": "#/$defs/integrationHttpConfig" } },
            "required": ["config"]
          }
        }
      ]
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 }
      }
    }
  }
}
