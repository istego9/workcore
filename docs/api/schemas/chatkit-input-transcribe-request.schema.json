{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChatKitInputTranscribeRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Optional integration metadata propagated with request.",
      "additionalProperties": true
    },
    "type": {
      "type": "string",
      "enum": ["input.transcribe"]
    },
    "params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "audio_base64": {
          "type": "string",
          "description": "Base64-encoded audio payload."
        },
        "mime_type": {
          "type": "string",
          "description": "Raw audio MIME type, e.g. audio/webm;codecs=opus."
        }
      },
      "required": ["audio_base64", "mime_type"]
    }
  },
  "required": ["type", "params"]
}
